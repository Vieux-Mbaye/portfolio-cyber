---
import { getCollection, render } from "astro:content";
import "../../styles/global.css";
import GlobalCyberEffects from "../../components/GlobalCyberEffects.jsx";
import JapaneseRain from "../../components/JapaneseRain.jsx";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const formatDate = (date) =>
  new Intl.DateTimeFormat("fr-FR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(date);
---

<html lang={article.data.language}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{article.data.title} | Vieux Mbaye NDOUR</title>
    <meta name="description" content={article.data.description} />
  </head>
  <body class="min-h-screen bg-slate-950 text-white font-mono">
    <GlobalCyberEffects client:load />
    <JapaneseRain client:load />

    <main class="relative z-10">
      <article class="min-h-screen px-4 sm:px-6 py-16 sm:py-20 cyber-grid bg-slate-950/82">
        <div class="max-w-4xl mx-auto">
          <nav class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-12">
            <a href="/articles/" class="text-emerald-300 hover:text-emerald-200 font-bold">← Articles</a>
            <a href="/" class="text-slate-200 hover:text-emerald-300">Portfolio</a>
          </nav>

          <header class="mb-10">
            <div class="text-sm text-emerald-200 mb-4">{formatDate(article.data.publishDate)}</div>
            <h1 class="text-[clamp(2rem,9vw,3.75rem)] font-bold text-white leading-tight mb-5 break-words">{article.data.title}</h1>
            <p class="readability-panel px-5 py-4 text-base md:text-xl text-slate-200 leading-relaxed">{article.data.description}</p>
            <div class="flex flex-wrap gap-2 mt-6">
              {article.data.tags.map((tag) => (
                <span class="px-2 py-1 text-xs rounded border border-emerald-700/70 bg-emerald-950/50 text-emerald-100">
                  {tag}
                </span>
              ))}
            </div>
          </header>

          {article.data.cover && (
            <img src={article.data.cover} alt="" class="w-full max-h-[420px] object-cover rounded-lg cyber-border mb-10" />
          )}

          <div class="article-content cyber-border rounded-lg bg-slate-900/88 p-5 sm:p-6 md:p-10">
            <Content />
          </div>
        </div>
      </article>
    </main>
  </body>
</html>
